# Example environment file (safe placeholders)
# Copy to .env.local and populate real secrets locally or via CI/CD secrets.

# Analytics (public)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Auth0 (server-side secrets must be kept secret)
AUTH0_SECRET=your-auth0-secret
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# APP_BASE_URL is for local development and non-Vercel deployments only.
# On Vercel, VERCEL_PROJECT_PRODUCTION_URL is detected automatically — do NOT
# copy this localhost value into your Vercel environment variables.
APP_BASE_URL=http://localhost:3001

# Set to 'true' to enable Auth0 login (required for client-side detection)
NEXT_PUBLIC_AUTH0_ENABLED=true

# MongoDB
DATABASE_URL=mongodb://localhost:27017/personal-finance-tracker-dev
MONGODB_DB_NAME=personal-finance-tracker-dev

# Open Banking sandbox imports (optional)
# Set to the provider sandbox base URL documented by OpenBankingTracker:
# - https://www.openbankingtracker.com/provider/caixabank
# - https://www.openbankingtracker.com/provider/bbva
# - https://www.openbankingtracker.com/provider/revolut
OPEN_BANKING_CAIXABANK_SANDBOX_URL=
OPEN_BANKING_BBVA_SANDBOX_URL=
OPEN_BANKING_REVOLUT_SANDBOX_URL=
# Optional bearer token used by sandbox endpoints.
# Token forwarding is restricted to trusted provider hostnames.
OPEN_BANKING_SANDBOX_TOKEN=
